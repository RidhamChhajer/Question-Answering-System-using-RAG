# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Generated pipeline artifacts ────────────────────────────────────────────────
# Chunks produced by Phase 1 — regenerated by `python main.py --phase 1`
processed/chunks.json

# FAISS index and metadata produced by Phase 2 — regenerated by `python main.py --phase 2`
vector_store/faiss_index.bin
vector_store/metadata.json

# ── User documents ──────────────────────────────────────────────────────────────
# Do NOT commit personal/private PDFs to a public repository
data/raw_pdfs/*.pdf
data/raw_pdfs/*.PDF

# Keep the folders themselves tracked (via .gitkeep files)
!data/raw_pdfs/.gitkeep
!processed/.gitkeep
!vector_store/.gitkeep

# ── Sentence-transformers / HuggingFace model cache ────────────────────────────
# These are large downloaded model weights — let each user download their own
.cache/
models/
*.bin
!vector_store/.gitkeep

# ── IDE & OS ────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.DS_Store
Thumbs.db
desktop.ini

# ── Environment secrets ────────────────────────────────────────────────────────
.env
.env.local
*.env

# ── Logs & temp files ──────────────────────────────────────────────────────────
*.log
*.tmp
tmp/
